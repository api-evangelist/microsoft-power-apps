        },
        "address1_city": {
          "@id": "schema:addressLocality",
          "@type": "xsd:string"
        },
        "address1_stateorprovince": {
          "@id": "schema:addressRegion",
          "@type": "xsd:string"
        },
        "address1_postalcode": {
          "@id": "schema:postalCode",
